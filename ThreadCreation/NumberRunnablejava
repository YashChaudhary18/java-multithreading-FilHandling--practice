package ThreadCreation;
// Thread using Runnable interface

public class NumberRunnable implements Runnable {

    @Override
    public void run() {

        for (int i = 1; i <= 10; i++) {

            System.out.println("Runnable: " + i);

            try {
                Thread.sleep(500);
            } catch (InterruptedException e) {
                System.out.println(e.getMessage());
            }
        }
    }
}
